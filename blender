<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blender</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #fdf6e3;
            color: #1e293b;
        }

        header {
            text-align: center;
            padding: 40px 20px 20px;
        }

        header h1 {
            margin: 0;
            font-size: 36px;
        }

        header p {
            margin-top: 10px;
            color: #475569;
        }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background: #d2a679;
            color: #3b2f2f;
            padding: 8px 14px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 14px;
            transition: 0.3s;
        }

        .back-btn:hover {
            background: #b88a5a;
        }

        .section {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 40px;
            padding: 40px 20px;
            max-width: 1000px;
            margin: auto;
        }

        .section:nth-child(even) {
            flex-direction: row-reverse;
        }

        .video {
            width: 400px;
            height: 225px;
            background: #d2a679;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #3b2f2f;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .text {
            max-width: 400px;
            color: #475569;
        }

        footer {
            text-align: center;
            padding: 15px;
            background: #d2a679;
            color: #3b2f2f;
            font-size: 14px;
        }

        @media (max-width: 768px) {
            .section {
                flex-direction: column !important;
            }
        }
    </style>
</head>

<body>

<a href="index.html" class="back-btn">← Back</a>

<header>
